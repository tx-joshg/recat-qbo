# App
# Public URL of this deployment — must match what users type in the browser.
# Docker quickstart: http://localhost:3001 · local dev (Vite): http://localhost:5173
# Production: your real https:// domain (also becomes the Intuit redirect URI base).
APP_URL=http://localhost:3001
PORT=3001
SESSION_SECRET=                      # random 32+ chars
ENCRYPTION_KEY=                      # 32-byte key (64 hex chars) for token encryption at rest

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recat

# QuickBooks (each deployer supplies their own — see docs/intuit-setup.md)
# May instead be entered in the first-run setup wizard (stored encrypted in the DB);
# env vars take precedence if present.
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_ENVIRONMENT=sandbox              # sandbox | production
QBO_WEBHOOK_VERIFIER_TOKEN=          # optional; only if webhooks enabled

# Local dev only: enables the demo seed (`npm run seed`). The app itself
# offers demo companies from the setup wizard on every deployment — no env
# var needed to try Recat without an Intuit account.
QBO_MOCK=false

# Email (magic links + daily digest) — any SMTP provider.
# If unset, magic links are printed to the server log instead (dev mode).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Recat <noreply@example.com>"

# Optional local administrator login for self-hosted/LAN deployments.
# A password of at least 12 characters enables it for existing instance admins.
# Set the email too when the deployment should pin access to one administrator.
# Umbrel packages can set only LOCAL_ADMIN_PASSWORD=${APP_PASSWORD}.
LOCAL_ADMIN_EMAIL=
LOCAL_ADMIN_PASSWORD=

# Optional comma-separated browser origins allowed to submit mutations while
# APP_URL remains the canonical public URL used for OAuth callbacks.
TRUSTED_ORIGINS=

# Optional comma-separated exact IPs of immediate reverse-proxy peers.
# Leave empty to trust none; direct or untrusted requests safely ignore
# X-Forwarded-For. Set an Umbrel/app-proxy peer IP when it forwards clients.
TRUSTED_PROXY_IPS=

# Optional
SLACK_WEBHOOK_URL=                   # digest notifications to Slack
DRY_RUN=false                        # true = never write to QBO, log what would happen
DIGEST_HOUR=8                        # local hour to send the daily digest

# DANGER — normally leave false. When SMTP is unset, magic-link login URLs
# are auto-returned in API responses ONLY while no real QuickBooks company is
# connected (a demo-only instance holds nothing sensitive); the moment real
# books attach, links go to email / the server log instead. Setting this true
# FORCES links into API responses even with real books connected — anyone who
# can reach the login form can then sign in as any user. Private dev only.
ALLOW_DEV_LOGIN=false

# Opt-in Purchase-tax sandbox contract harness. All gates are required and the
# fixture must be synthetic with PrivateNote beginning "[RECAT TAX SANDBOX]".
# Never put access/refresh token values in a committed env file.
QBO_TAX_SANDBOX_TEST=false
QBO_TAX_SANDBOX_REALM_ALLOWLIST=
QBO_TAX_SANDBOX_REALM_ID=
QBO_TAX_SANDBOX_PURCHASE_ID=
QBO_TAX_SANDBOX_HOLDING_ACCOUNT_ID=
QBO_TAX_SANDBOX_CATEGORY_ACCOUNT_ID=
QBO_TAX_SANDBOX_TAX_CODE_ID=
QBO_TAX_SANDBOX_TAX_CALCULATION=TaxInclusive
QBO_TAX_SANDBOX_ACCESS_TOKEN=
QBO_TAX_SANDBOX_REFRESH_TOKEN=
